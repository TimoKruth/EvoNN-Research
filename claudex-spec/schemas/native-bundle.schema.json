{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evonn.local/schemas/native-bundle/1.0.0",
  "title": "EvoNN Native Bundle Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "bundle_id", "model_version_id", "created_at", "dependency_mode", "runtime", "task", "input_schema", "output_schema", "files", "dependencies", "provenance", "licenses", "verification"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "bundle_id": {"$ref": "#/$defs/ulid"},
    "model_version_id": {"$ref": "#/$defs/ulid"},
    "created_at": {"type": "string", "format": "date-time"},
    "dependency_mode": {"enum": ["embedded", "content_addressed_local"]},
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "exact_version", "environment_lock_digest", "platforms"],
      "properties": {
        "backend": {"type": "string"},
        "exact_version": {"type": "string"},
        "environment_lock_digest": {"$ref": "#/$defs/digest"},
        "platforms": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "digest"],
      "properties": {"id": {"type": "string"}, "version": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}}
    },
    "input_schema": {"type": "object"},
    "output_schema": {"type": "object"},
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "media_type", "size_bytes", "digest"],
        "properties": {
          "path": {"type": "string", "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"},
          "role": {"type": "string"},
          "media_type": {"type": "string"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "digest": {"$ref": "#/$defs/digest"}
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "digest", "required_offline", "license_status"],
        "properties": {
          "kind": {"type": "string"},
          "digest": {"$ref": "#/$defs/digest"},
          "required_offline": {"const": true},
          "license_status": {"enum": ["approved", "restricted"]}
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataset_version_id", "job_id", "candidate_id", "evaluation_ids"],
      "properties": {
        "dataset_version_id": {"$ref": "#/$defs/ulid"},
        "job_id": {"$ref": "#/$defs/ulid"},
        "candidate_id": {"$ref": "#/$defs/ulid"},
        "evaluation_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/ulid"}}
      }
    },
    "licenses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component", "status"],
        "properties": {"component": {"type": "string"}, "spdx": {"type": ["string", "null"]}, "status": {"enum": ["approved", "restricted"]}, "notice_path": {"type": ["string", "null"]}}
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "verifier_id", "verifier_version", "verified_at", "evidence_digest", "test_vectors"],
      "properties": {
        "status": {"enum": ["verified", "failed"]},
        "verifier_id": {"type": "string"},
        "verifier_version": {"type": "string"},
        "verified_at": {"type": "string", "format": "date-time"},
        "evidence_digest": {"$ref": "#/$defs/digest"},
        "test_vectors": {"type": "array", "minItems": 1, "items": {"type": "object"}},
        "signature": {"type": ["object", "null"]}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"dependency_mode": {"const": "embedded"}}},
      "then": {"properties": {"dependencies": {"maxItems": 0}}}
    },
    {
      "if": {"properties": {"dependency_mode": {"const": "content_addressed_local"}}},
      "then": {"properties": {"dependencies": {"minItems": 1}}}
    }
  ],
  "$defs": {
    "ulid": {"type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"},
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {"algorithm": {"enum": ["sha256", "sha512"]}, "value": {"type": "string", "pattern": "^[0-9a-f]{64}([0-9a-f]{64})?$"}}
    }
  }
}
