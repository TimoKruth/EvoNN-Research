{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evonn.local/schemas/split-artifact/1.0.0",
  "title": "EvoNN Split Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "split_id", "dataset_version_id", "generator", "seed", "assignments_digest", "roles", "dependence_policy", "leakage_report_digest"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "split_id": {"$ref": "#/$defs/ulid"},
    "dataset_version_id": {"$ref": "#/$defs/ulid"},
    "generator": {"type": "object", "additionalProperties": false, "required": ["id", "version", "digest"], "properties": {"id": {"type": "string"}, "version": {"type": "string"}, "digest": {"$ref": "#/$defs/digest"}}},
    "seed": {"type": "integer", "minimum": 0},
    "assignments_digest": {"$ref": "#/$defs/digest"},
    "roles": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"enum": ["train", "validation", "test", "calibration", "holdout"]}},
    "dependence_policy": {"type": "object"},
    "temporal_spatial_policy": {"type": "object"},
    "leakage_report_digest": {"$ref": "#/$defs/digest"}
  },
  "$defs": {
    "ulid": {"type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"},
    "digest": {"type": "object", "additionalProperties": false, "required": ["algorithm", "value"], "properties": {"algorithm": {"enum": ["sha256", "sha512"]}, "value": {"type": "string", "pattern": "^[0-9a-f]{64}([0-9a-f]{64})?$"}}}
  }
}
