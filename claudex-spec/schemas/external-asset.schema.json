{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evonn.local/schemas/external-asset/1.0.0",
  "title": "EvoNN External Model/Data Asset",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "asset_id", "kind", "source", "resolved_revision", "files", "license_status", "training_data_cutoff", "overlap_status", "eligibility"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "asset_id": {"type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"},
    "kind": {"enum": ["pretrained_model", "tokenizer", "processor", "embedding_model", "teacher", "retrieval_corpus", "synthetic_generator", "feature_producer"]},
    "source": {"type": "string"},
    "resolved_revision": {"type": "string"},
    "files": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["path", "sha256"], "properties": {"path": {"type": "string"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}}},
    "license_status": {"enum": ["approved", "restricted", "unknown", "denied"]},
    "training_data_cutoff": {"type": ["string", "null"]},
    "overlap_status": {"enum": ["cleared", "declared_overlap", "suspected", "unknown", "prohibited"]},
    "overlap_evidence": {"type": "object"},
    "eligibility": {"enum": ["decision_grade", "operational_only", "ineligible"]},
    "eligibility_reason": {"type": "string"}
  },
  "allOf": [
    {"if": {"properties": {"overlap_status": {"enum": ["suspected", "unknown"]}}}, "then": {"properties": {"eligibility": {"const": "operational_only"}}}},
    {"if": {"properties": {"overlap_status": {"const": "prohibited"}}}, "then": {"properties": {"eligibility": {"const": "ineligible"}}}}
  ]
}
