{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evonn.local/schemas/dataset-descriptor/1.0.0",
  "title": "EvoNN Dataset Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dataset_id", "dataset_version_id", "slug", "dataset_version", "canonical_digest", "title", "owner", "lifecycle", "sources", "provenance", "sample_identity", "modalities", "target", "governance", "split_policy", "preprocessing", "known_limitations"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "dataset_id": {"$ref": "#/$defs/ulid"},
    "dataset_version_id": {"$ref": "#/$defs/ulid"},
    "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._/-]+$"},
    "dataset_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "canonical_digest": {"$ref": "#/$defs/digest"},
    "title": {"type": "string", "minLength": 1},
    "owner": {"type": "object", "additionalProperties": false, "required": ["authority"], "properties": {"authority": {"type": "string", "minLength": 1}, "contact": {"type": ["string", "null"]}}},
    "lifecycle": {"enum": ["draft", "active", "deprecated", "revoked"]},
    "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}},
    "provenance": {"type": "object", "additionalProperties": false, "required": ["lineage_digest", "acquisition_recipe"], "properties": {"lineage_digest": {"$ref": "#/$defs/digest"}, "acquisition_recipe": {"type": "object"}, "citations": {"type": "array", "items": {"type": "string"}}}},
    "sample_identity": {"type": "object", "additionalProperties": false, "required": ["rule"], "properties": {"rule": {"type": "string"}, "group_keys": {"type": "array", "items": {"type": "string"}}, "time_key": {"type": ["string", "null"]}, "availability_time_key": {"type": ["string", "null"]}, "geography_key": {"type": ["string", "null"]}, "duplicate_family_rule": {"type": ["string", "null"]}}},
    "modalities": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/modality"}},
    "multimodal_alignment": {"oneOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["sample_key", "cardinality", "missing_policy"], "properties": {"sample_key": {"type": "string"}, "cardinality": {"enum": ["one_to_one", "one_to_many", "many_to_one", "many_to_many"]}, "ordering_or_time_rule": {"type": ["string", "null"]}, "missing_policy": {"enum": ["reject", "exclude_incomplete", "allow_optional", "candidate_compatibility"]}, "join_digest": {"$ref": "#/$defs/digest"}}}]},
    "target": {"type": "object", "additionalProperties": false, "required": ["name", "schema", "ontology"], "properties": {"name": {"type": "string"}, "schema": {"type": "object"}, "ontology": {"type": "object"}}},
    "governance": {"$ref": "#/$defs/governance"},
    "split_policy": {"type": "object", "additionalProperties": false, "required": ["strategy", "version", "seed"], "properties": {"strategy": {"type": "string"}, "version": {"type": "string"}, "seed": {"type": "integer", "minimum": 0}, "group_keys": {"type": "array", "items": {"type": "string"}}, "stratification_keys": {"type": "array", "items": {"type": "string"}}, "temporal_cutoff": {"type": ["string", "null"]}, "embargo": {"type": ["string", "null"]}, "near_duplicate_policy": {"type": "object"}}},
    "preprocessing": {"type": "array", "items": {"$ref": "#/$defs/transform"}},
    "known_limitations": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "ulid": {"type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"},
    "digest": {"type": "object", "additionalProperties": false, "required": ["algorithm", "value"], "properties": {"algorithm": {"enum": ["sha256", "sha512"]}, "value": {"type": "string", "pattern": "^[0-9a-f]{64}([0-9a-f]{64})?$"}}},
    "source": {"type": "object", "additionalProperties": false, "required": ["uri", "publisher", "acquired_at", "media_type", "packaging", "checksum", "license_status", "privacy_class"], "properties": {"uri": {"type": "string"}, "publisher": {"type": "string"}, "acquired_at": {"type": "string", "format": "date-time"}, "resolved_revision": {"type": ["string", "null"]}, "media_type": {"type": "string"}, "packaging": {"type": "string"}, "size_bytes": {"type": ["integer", "null"], "minimum": 0}, "checksum": {"$ref": "#/$defs/digest"}, "signature": {"type": ["object", "null"]}, "license_status": {"enum": ["approved", "restricted", "unknown", "denied"]}, "privacy_class": {"enum": ["public", "internal", "sensitive", "restricted", "unknown"]}, "authentication_class": {"type": ["string", "null"]}}},
    "modality": {"type": "object", "additionalProperties": false, "required": ["name", "kind", "required", "schema", "missing_semantics"], "properties": {"name": {"type": "string"}, "kind": {"enum": ["tabular", "image", "text", "audio", "video", "time_series", "sequence", "graph", "tensor", "structured"]}, "required": {"type": "boolean"}, "schema": {"type": "object"}, "units": {"type": ["object", "null"]}, "encoding": {"type": ["string", "null"]}, "missing_semantics": {"type": "string"}}},
    "governance": {"type": "object", "additionalProperties": false, "required": ["license_status", "license_terms", "privacy_class", "permitted_uses", "processing_locations", "preview_policy"], "properties": {"license_status": {"enum": ["approved", "restricted", "unknown", "denied"]}, "license_id": {"type": ["string", "null"]}, "license_terms": {"type": "object"}, "privacy_class": {"enum": ["public", "internal", "sensitive", "restricted", "unknown"]}, "personal_data": {"type": "array", "items": {"type": "string"}}, "jurisdictions": {"type": "array", "items": {"type": "string"}}, "permitted_uses": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "processing_locations": {"type": "array", "items": {"type": "string"}}, "retention_days": {"type": ["integer", "null"], "minimum": 0}, "deletion_policy": {"type": ["string", "null"]}, "preview_policy": {"enum": ["disabled", "redacted", "authorized"]}}},
    "transform": {"type": "object", "additionalProperties": false, "required": ["op", "version", "scope", "params"], "properties": {"op": {"type": "string"}, "version": {"type": "string"}, "scope": {"enum": ["stateless", "train_fitted", "label_fitted", "stochastic"]}, "params": {"type": "object"}, "implementation_digest": {"$ref": "#/$defs/digest"}}}
  }
}
