{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evonn.local/schemas/confirmatory-evidence/1.0.0",
  "title": "EvoNN Confirmatory Test Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "evidence_id", "model_version_id", "dataset_version_id", "split_id", "preprocessing_digest", "test_policy_digest", "runtime", "metrics", "test_query_ordinal", "audit_digest", "outcome", "created_at"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "evidence_id": {"$ref": "#/$defs/ulid"},
    "model_version_id": {"$ref": "#/$defs/ulid"},
    "dataset_version_id": {"$ref": "#/$defs/ulid"},
    "split_id": {"$ref": "#/$defs/ulid"},
    "preprocessing_digest": {"$ref": "#/$defs/digest"},
    "test_policy_digest": {"$ref": "#/$defs/digest"},
    "runtime": {"type": "object", "additionalProperties": false, "required": ["backend", "capability_digest", "platform_fingerprint"], "properties": {"backend": {"type": "string"}, "capability_digest": {"$ref": "#/$defs/digest"}, "platform_fingerprint": {"$ref": "#/$defs/digest"}}},
    "metrics": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["metric_id", "metric_version", "value", "direction", "uncertainty"], "properties": {"metric_id": {"type": "string"}, "metric_version": {"type": "string"}, "value": {"type": "number"}, "direction": {"enum": ["min", "max"]}, "uncertainty": {"type": ["object", "null"]}}}},
    "authorized_subgroup_aggregates": {"type": "array", "items": {"type": "object"}},
    "test_query_ordinal": {"type": "integer", "minimum": 1},
    "audit_digest": {"$ref": "#/$defs/digest"},
    "outcome": {"enum": ["valid", "valid_with_warnings", "failed", "invalidated"]},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "ulid": {"type": "string", "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"},
    "digest": {"type": "object", "additionalProperties": false, "required": ["algorithm", "value"], "properties": {"algorithm": {"enum": ["sha256", "sha512"]}, "value": {"type": "string", "pattern": "^[0-9a-f]{64}([0-9a-f]{64})?$"}}}
  }
}
